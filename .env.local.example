# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Stripe secret key (starts with sk_test_... or sk_live_...)
# Found in Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=

# The Price ID for your $9.99/month subscription (starts with price_...)
# Found in Stripe Dashboard > Product catalog > click your product > copy the Price ID
STRIPE_PRICE_ID=

# Random secret used to sign the access cookie. Any long random string works —
# it doesn't come from Stripe, it's just for this app.
COOKIE_SECRET=

# Resend API key, used to send security/fraud alert emails.
# Found in Resend Dashboard > API Keys, after creating a free account at resend.com
RESEND_API_KEY=

# Signing secret for the Stripe webhook that reports fraud warnings/disputes.
# Found in Stripe Dashboard > Developers > Webhooks > click your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=
